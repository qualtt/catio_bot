# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id_here
CHANNEL_ID=@your_channel_username_or_id

# One-off channel history importer (Pyrogram userbot)
API_ID=
API_HASH=
USERBOT_SESSION_STRING=
USERBOT_SESSION_NAME=catio_importer

# Database
POSTGRES_USER=catio_bot
POSTGRES_PASSWORD=bot_password
POSTGRES_DB=catio_bot_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# S3-compatible photo storage
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_BUCKET=catio-bot-photos
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=catio-bot/photos
S3_FORCE_PATH_STYLE=false

# Scheduling
TIMEZONE=Europe/Moscow
DAILY_SLOT_TIMES=11:00
AUTO_POST_DAYS_AHEAD=30
PUBLISHER_POLL_INTERVAL_SECONDS=60
DUPLICATE_PHASH_MAX_DISTANCE=8

# Scoring
SCORE_APPROVED_POST_BASE=100
SCORE_AUTO_BONUS_MIN_PERCENT=10
SCORE_AUTO_BONUS_MAX_PERCENT=20
SCORE_PENDING_POST_WEIGHT_PERCENT=50
SCORE_DUPLICATE_EXACT_FACTOR_PERCENT=0
SCORE_DUPLICATE_SIMILAR_FACTOR_PERCENT=50
SCORE_OLD_PHOTO_CORRECT=3
SCORE_OLD_PHOTO_DAILY_CAP=30

# Old photo identification
IDENTIFICATION_VOTES_REQUIRED=1
IDENTIFICATION_CONSENSUS_PERCENT=67
IDENTIFICATION_MAX_VOTES_PER_PHOTO=7
IDENTIFICATION_ASSIGNMENT_TTL_MINUTES=30
IDENTIFICATION_BATCH_SIZE=10
IDENTIFICATION_MAX_ACTIVE_ASSIGNMENTS_PER_PHOTO=3

# Photo tournaments
PHOTO_TOURNAMENTS_ENABLED=true
PHOTO_TOURNAMENT_NOTIFY_HOUR=12
PHOTO_TOURNAMENT_NOTIFY_MINUTE=0
PHOTO_TOURNAMENT_ROUND_HOURS=24
PHOTO_TOURNAMENT_MIN_ENTRIES=2
PHOTO_TOURNAMENT_MONTHLY_WEEKS=4

# Editable bot content
BOT_CONTENT_PATH=bot_content.json
